SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Swap these to match your real analytics table and columns.
SUPABASE_ANALYTICS_TABLE=analytics_events
SUPABASE_ANALYTICS_ID_COLUMN=id
SUPABASE_ANALYTICS_CREATED_AT_COLUMN=created_at
SUPABASE_ANALYTICS_CLIENT_COLUMN=client_name
SUPABASE_ANALYTICS_CAMPAIGN_COLUMN=campaign_name
SUPABASE_ANALYTICS_SOURCE_COLUMN=source_platform
SUPABASE_ANALYTICS_SEARCH_COLUMN_PRIMARY=message_text
SUPABASE_ANALYTICS_SEARCH_COLUMN_SECONDARY=external_id
SUPABASE_ANALYTICS_TABLE_COLUMNS=created_at,client_name,campaign_name,source_platform,message_text,external_id

# Dashboard behavior
ANALYTICS_DASHBOARD_PAGE_SIZE=50
ANALYTICS_AGGREGATION_SAMPLE_SIZE=5000
ANALYTICS_EXPORT_LIMIT=20000

# App
PORT=3000
