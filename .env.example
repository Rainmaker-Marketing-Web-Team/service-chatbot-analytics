DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-1-eu-west-1.pooler.supabase.com:6543/postgres

# Optional fallback if you want to use the Supabase API client instead of DATABASE_URL.
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Display name shown in the dashboard metadata.
ANALYTICS_DATA_SOURCE_NAME=chat_messages + chat_sessions + projects

# Column aliases produced by the relational query layer.
SUPABASE_ANALYTICS_TABLE=chat_messages + chat_sessions + projects
SUPABASE_ANALYTICS_ID_COLUMN=id
SUPABASE_ANALYTICS_CREATED_AT_COLUMN=created_at
SUPABASE_ANALYTICS_CLIENT_COLUMN=project_name
SUPABASE_ANALYTICS_CAMPAIGN_COLUMN=channel
SUPABASE_ANALYTICS_SOURCE_COLUMN=role
SUPABASE_ANALYTICS_SEARCH_COLUMN_PRIMARY=content
SUPABASE_ANALYTICS_SEARCH_COLUMN_SECONDARY=external_session_id
SUPABASE_ANALYTICS_TABLE_COLUMNS=created_at,project_name,project_slug,channel,role,external_user_id,external_session_id,content

# Dashboard behavior
ANALYTICS_DASHBOARD_PAGE_SIZE=50
ANALYTICS_AGGREGATION_SAMPLE_SIZE=5000
ANALYTICS_EXPORT_LIMIT=20000

# App
PORT=3000
